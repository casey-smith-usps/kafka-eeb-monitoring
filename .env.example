# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Python Backend URL (required for GitHub Pages deployment)
# For production: Set to your deployed backend URL (e.g., https://your-app.herokuapp.com)
# For local dev: Leave blank to use relative path
VITE_BACKEND_URL=

# Supabase Service Role Key (required for Python backend sync script)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Confluent Cloud Configuration
CONFLUENT_ENV_ID=your_env_id_here
CONFLUENT_CLUSTER_ID=your_cluster_id_here
CONFLUENT_API_KEY=your_api_key_here
CONFLUENT_API_SECRET=your_api_secret_here

# Frontend environment variables (VITE_ prefix makes them available in browser)
VITE_CONFLUENT_ADMIN_URL=https://pkc-xxxxx.region.cloud.confluent.cloud
VITE_CONFLUENT_CLUSTER_ID=your_cluster_id_here
VITE_CONFLUENT_API_KEY=your_api_key_here
VITE_CONFLUENT_API_SECRET=your_api_secret_here

# Corporate Proxy Settings (if behind firewall - USPS users need this)
# Example: HTTP_PROXY=http://proxy.company.com:8080
# Example: HTTPS_PROXY=http://proxy.company.com:8080
# If authentication required: http://username:password@proxy.company.com:8080
HTTP_PROXY=
HTTPS_PROXY=

# Splunk Configuration (for performance metrics streaming)
SPLUNK_HOST=https://your-splunk-host.com:8089
SPLUNK_TOKEN=your_splunk_token_here

# Microsoft Graph API (for Outlook incident streaming)
# Note: Access tokens are obtained through OAuth flow in the application
# These are not stored in .env but configured at runtime
MICROSOFT_TENANT_ID=your_tenant_id_here
MICROSOFT_CLIENT_ID=your_client_id_here
