# Azure AD Authentication
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here

# Azure API Endpoint (APIM or Function App URL)
VITE_API_BASE_URL=https://kafka-monitoring-apim.azure-api.net

# Optional: Direct Function URLs (for testing)
VITE_KAFKA_SYNC_URL=https://kafka-monitoring-functions.azurewebsites.net/api/kafka-sync
VITE_DATABRICKS_AI_URL=https://kafka-monitoring-functions.azurewebsites.net/api/databricks-ai

# Keep Supabase for database (or comment out if using Azure SQL)
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Feature Flags
VITE_USE_AZURE_AUTH=true
VITE_USE_AZURE_FUNCTIONS=true
